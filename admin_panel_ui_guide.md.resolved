│   │   ├── ui/
│   │   │   ├── Button.tsx
│   │   │   ├── Input.tsx
│   │   │   └── ... (Tables, Modals, Badges)
│   │   └── shared/
│   ├── hooks/                     ← Custom hooks (useAuth, useFetch)
│   ├── layouts/                   ← Layout components
│   ├── lib/                       ← API config (axios/fetch)
│   ├── pages/                     ← Page components
│   │   ├── auth/
│   │   │   ├── Login.tsx
│   │   │   └── ForgotPassword.tsx
│   │   ├── Dashboard.tsx
│   │   ├── Inquiries.tsx
│   │   ├── blogs/
│   │   │   ├── BlogList.tsx
│   │   │   ├── CreateBlog.tsx
│   │   │   └── EditBlog.tsx
│   │   ├── Employees.tsx
│   │   ├── Products.tsx
│   │   ├── Portfolio.tsx
│   │   ├── DemoRequests.tsx
│   │   ├── JobApplications.tsx
│   │   ├── Newsletter.tsx
│   │   └── Settings.tsx
│   ├── store/                     ← State management (Zustand/Context)
│   ├── App.tsx                    ← Routing configuration
│   └── main.tsx                   ← Entry point
├── .env                           ← Environment variables
├── index.html
└── vite.config.ts
```

